# DeeFacto Frontend 환경변수 설정
# 이 파일을 복사하여 .env 파일을 만들고 실제 값으로 수정하세요

# ===== API Gateway 설정 =====
VITE_API_GATEWAY_URL=http://localhost:8080
VITE_API_GATEWAY_BASE_PATH=/api

# ===== 개발 환경 설정 =====
VITE_NODE_ENV=development
VITE_APP_TITLE=DeeFacto
VITE_APP_VERSION=1.0.0

# ===== 기능 설정 =====
VITE_ENABLE_DEBUG_LOGGING=true
VITE_ENABLE_CORS=true

# ===== 타임아웃 설정 =====
VITE_API_TIMEOUT=10000
VITE_SSE_TIMEOUT=30000

# ===== 로깅 설정 =====
VITE_LOG_LEVEL=info
VITE_LOG_TO_CONSOLE=true

# ===== 배포 환경별 설정 =====
# 개발 환경
# VITE_API_GATEWAY_URL=http://localhost:8080
# VITE_NODE_ENV=development

# 스테이징 환경
# VITE_API_GATEWAY_URL=https://staging-api.deefacto.com
# VITE_NODE_ENV=staging

# 프로덕션 환경
# VITE_API_GATEWAY_URL=https://api.deefacto.com
# VITE_NODE_ENV=production